    {
      "name": "🔒 Protegido — Perfil",
      "item": [
        {
          "name": "GET Meu Perfil",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Senha não retornada', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.not.have.property('password');",
                  "});"
