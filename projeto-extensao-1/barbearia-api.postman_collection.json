    {
      "name": "🔒 Protegido — Agendamentos",
      "item": [
        {
          "name": "GET Todos os Agendamentos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/barber/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "barber", "appointments"]
            },
            "description": "Lista todos os agendamentos do barbeiro autenticado, com paginação."
          },
          "response": []
        },
        {
          "name": "GET Agendamentos — Filtrar por Data",
          "request": {
            "method": "GET",
