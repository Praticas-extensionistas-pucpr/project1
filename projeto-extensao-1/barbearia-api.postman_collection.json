                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{baseUrl}}/api/barber/register", "host": ["{{baseUrl}}"], "path": ["api", "barber", "register"] },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Pedro Tesoura\",\n  \"email\": \"pedro@barbearia.com\",\n  \"password\": \"senha456\",\n  \"phone\": \"(11) 88888-0002\"\n}"
