{
  "info": {
    "name": "Barbearia API",
    "description": "Collection completa para testes da API de agendamento de serviços de barbearia.\n\n## Como usar\n1. Execute o seed: `POST /api/seed`\n2. Faça login: `POST /api/auth/login` — o token JWT é salvo automaticamente na variável `{{token}}`\n3. Use as demais rotas normalmente\n\n## Variáveis de ambiente\n- `baseUrl`: URL base da API (padrão: http://localhost:3000)\n- `token`: preenchido automaticamente após o login\n- `barberId`: preenchido automaticamente após listar barbeiros\n- `serviceId`: preenchido automaticamente após listar serviços\n- `appointmentId`: preenchido automaticamente após criar agendamento",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "barberId", "value": "", "type": "string" },
    { "key": "serviceId", "value": "", "type": "string" },
    { "key": "appointmentId", "value": "", "type": "string" },
    { "key": "serviceIdManaged", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🌱 Setup",
      "item": [
        {
          "name": "Seed — Popula banco de dados",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/seed", "host": ["{{baseUrl}}"], "path": ["api", "seed"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secret\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Popula o banco com 6 serviços e 1 barbeiro demo.\n\nCredenciais do demo:\n- Email: joao@barbearia.com\n- Senha: senha123\n\n⚠️  Disponível apenas em desenvolvimento."
          },
          "response": [
            {
              "name": "200 — Seed executado",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{baseUrl}}/api/seed", "host": ["{{baseUrl}}"], "path": ["api", "seed"] },
                "body": { "mode": "raw", "raw": "{}", "options": { "raw": { "language": "json" } } }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Seed executado com sucesso!\",\n  \"data\": {\n    \"servicesCreated\": 6,\n    \"barberCreated\": 0,\n    \"demoCredentials\": {\n      \"email\": \"joao@barbearia.com\",\n      \"password\": \"senha123\"\n    }\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "🔓 Público — Cliente",
      "item": [
        {
          "name": "GET Serviços",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "    pm.collectionVariables.set('serviceId', json.data[0]._id);",
                  "    console.log('serviceId salvo:', json.data[0]._id);",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna array de serviços', () => {",
                  "    pm.expect(json.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/services", "host": ["{{baseUrl}}"], "path": ["api", "services"] },
            "description": "Retorna todos os serviços ativos.\n\nO primeiro `_id` retornado é salvo automaticamente em `{{serviceId}}`."
          },
          "response": [
            {
              "name": "200 — Lista de serviços",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/api/services", "host": ["{{baseUrl}}"], "path": ["api", "services"] }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [\n    {\n      \"_id\": \"665abc000000000000000001\",\n      \"name\": \"Corte Simples\",\n      \"description\": \"Corte tradicional na tesoura ou máquina.\",\n      \"durationMinutes\": 30,\n      \"price\": 35,\n      \"isActive\": true,\n      \"createdAt\": \"2026-03-08T10:00:00.000Z\",\n      \"updatedAt\": \"2026-03-08T10:00:00.000Z\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "GET Barbeiros",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.length > 0) {",
                  "    pm.collectionVariables.set('barberId', json.data[0]._id);",
                  "    console.log('barberId salvo:', json.data[0]._id);",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Retorna array de barbeiros', () => {",
                  "    pm.expect(json.data).to.be.an('array');",
                  "});",
                  "pm.test('Senha não é retornada', () => {",
                  "    if (json.data.length > 0) {",
                  "        pm.expect(json.data[0]).to.not.have.property('password');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/barbers", "host": ["{{baseUrl}}"], "path": ["api", "barbers"] },
            "description": "Retorna todos os barbeiros ativos. A senha nunca é retornada.\n\nO primeiro `_id` retornado é salvo automaticamente em `{{barberId}}`."
          },
          "response": [
            {
              "name": "200 — Lista de barbeiros",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/api/barbers", "host": ["{{baseUrl}}"], "path": ["api", "barbers"] }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [\n    {\n      \"_id\": \"665def000000000000000001\",\n      \"name\": \"João da Navalha\",\n      \"phone\": \"(11) 99999-0001\",\n      \"bio\": \"Barbeiro há 10 anos.\",\n      \"isActive\": true\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "GET Disponibilidade",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/availability?barberId={{barberId}}&serviceId={{serviceId}}&date=2026-03-15",
              "host": ["{{baseUrl}}"],
              "path": ["api", "availability"],
              "query": [
                { "key": "barberId", "value": "{{barberId}}", "description": "ID do barbeiro (preenchido automaticamente)" },
                { "key": "serviceId", "value": "{{serviceId}}", "description": "ID do serviço (preenchido automaticamente)" },
                { "key": "date", "value": "2026-03-15", "description": "Data no formato YYYY-MM-DD" }
              ]
            },
            "description": "Retorna os horários disponíveis para um barbeiro em uma data específica, levando em conta a duração do serviço escolhido.\n\nAjuste a `date` para uma data futura."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Retorna lista de slots', () => {",
                  "    pm.expect(json.data.availableSlots).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "200 — Horários disponíveis",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/api/availability?barberId={{barberId}}&serviceId={{serviceId}}&date=2026-03-15",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "availability"],
                  "query": [
                    { "key": "barberId", "value": "{{barberId}}" },
                    { "key": "serviceId", "value": "{{serviceId}}" },
                    { "key": "date", "value": "2026-03-15" }
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"barber\": { \"_id\": \"665def...\", \"name\": \"João da Navalha\" },\n    \"service\": { \"_id\": \"665abc...\", \"name\": \"Corte Simples\", \"durationMinutes\": 30 },\n    \"date\": \"2026-03-15\",\n    \"availableSlots\": [\"09:00\", \"09:30\", \"10:00\", \"10:30\", \"11:00\", \"11:30\", \"14:00\", \"14:30\"]\n  }\n}"
            },
            {
              "name": "400 — Parâmetros ausentes",
              "originalRequest": {
                "method": "GET",
                "url": { "raw": "{{baseUrl}}/api/availability", "host": ["{{baseUrl}}"], "path": ["api", "availability"] }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Parâmetros obrigatórios ausentes: barberId, serviceId e date são obrigatórios.\"\n}"
            },
            {
              "name": "400 — Data no passado",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/api/availability?barberId={{barberId}}&serviceId={{serviceId}}&date=2020-01-01",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "availability"],
                  "query": [
                    { "key": "barberId", "value": "{{barberId}}" },
                    { "key": "serviceId", "value": "{{serviceId}}" },
                    { "key": "date", "value": "2020-01-01" }
                  ]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Não é possível consultar disponibilidade para datas passadas.\"\n}"
            }
          ]
        },
        {
          "name": "POST Criar Agendamento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (pm.response.code === 201 && json.data) {",
                  "    pm.collectionVariables.set('appointmentId', json.data._id);",
                  "    console.log('appointmentId salvo:', json.data._id);",
                  "}",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Agendamento criado com status pending', () => {",
                  "    pm.expect(json.data.status).to.equal('pending');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/appointments", "host": ["{{baseUrl}}"], "path": ["api", "appointments"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientName\": \"Carlos Silva\",\n  \"clientPhone\": \"(11) 91234-5678\",\n  \"clientEmail\": \"carlos@email.com\",\n  \"clientNotes\": \"Prefiro degradê baixo.\",\n  \"barberId\": \"{{barberId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"date\": \"2026-03-15\",\n  \"timeSlot\": \"10:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Cria um novo agendamento. O `appointmentId` é salvo automaticamente.\n\n⚠️  Certifique-se de usar uma data futura e um horário disponível (consulte GET /api/availability antes)."
          },
          "response": [
            {
              "name": "201 — Agendamento criado",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{baseUrl}}/api/appointments", "host": ["{{baseUrl}}"], "path": ["api", "appointments"] },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"clientName\": \"Carlos Silva\",\n  \"clientPhone\": \"(11) 91234-5678\",\n  \"clientEmail\": \"carlos@email.com\",\n  \"barberId\": \"{{barberId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"date\": \"2026-03-15\",\n  \"timeSlot\": \"10:00\"\n}"
                }
              },
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Agendamento criado com sucesso!\",\n  \"data\": {\n    \"_id\": \"665ghi...\",\n    \"clientName\": \"Carlos Silva\",\n    \"clientPhone\": \"(11) 91234-5678\",\n    \"clientEmail\": \"carlos@email.com\",\n    \"barberId\": { \"_id\": \"665def...\", \"name\": \"João da Navalha\", \"phone\": \"(11) 99999-0001\" },\n    \"serviceId\": { \"_id\": \"665abc...\", \"name\": \"Corte Simples\", \"durationMinutes\": 30, \"price\": 35 },\n    \"date\": \"2026-03-15\",\n    \"timeSlot\": \"10:00\",\n    \"endTime\": \"10:30\",\n    \"status\": \"pending\",\n    \"createdAt\": \"2026-03-08T12:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "409 — Horário indisponível",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{baseUrl}}/api/appointments", "host": ["{{baseUrl}}"], "path": ["api", "appointments"] },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"clientName\": \"Ana Souza\",\n  \"clientPhone\": \"(11) 98765-4321\",\n  \"barberId\": \"{{barberId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"date\": \"2026-03-15\",\n  \"timeSlot\": \"10:00\"\n}"
                }
              },
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"error\": \"Horário indisponível. Por favor, escolha outro horário ou data.\"\n}"
            },
            {
              "name": "400 — Campos obrigatórios ausentes",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{baseUrl}}/api/appointments", "host": ["{{baseUrl}}"], "path": ["api", "appointments"] },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"clientName\": \"Carlos Silva\"\n}"
                }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Campos obrigatórios ausentes: clientName, clientPhone, barberId, serviceId, date e timeSlot.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "🔐 Auth — Barbeiro",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (pm.response.code === 200 && json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token JWT salvo com sucesso.');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token JWT retornado', () => {",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@barbearia.com\",\n  \"password\": \"senha123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Autentica o barbeiro e retorna um token JWT.\n\nO token é salvo automaticamente em `{{token}}` e usado nas próximas requisições protegidas."
          },
          "response": [
            {
              "name": "200 — Login bem-sucedido",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
                "body": { "mode": "raw", "raw": "{\n  \"email\": \"joao@barbearia.com\",\n  \"password\": \"senha123\"\n}" }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Login realizado com sucesso.\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"barber\": {\n    \"_id\": \"665def...\",\n    \"name\": \"João da Navalha\",\n    \"email\": \"joao@barbearia.com\",\n    \"phone\": \"(11) 99999-0001\"\n  }\n}"
            },
            {
              "name": "401 — Credenciais inválidas",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
                "body": { "mode": "raw", "raw": "{\n  \"email\": \"joao@barbearia.com\",\n  \"password\": \"senhaerrada\"\n}" }
              },
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"error\": \"Credenciais inválidas.\"\n}"
            }
          ]
        },
        {
          "name": "POST Registrar Barbeiro",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Register-Secret", "value": "segredo_de_registro", "description": "Obrigatório se REGISTER_SECRET estiver definido no .env.local" }
            ],
            "url": { "raw": "{{baseUrl}}/api/barber/register", "host": ["{{baseUrl}}"], "path": ["api", "barber", "register"] },
            "body": {
